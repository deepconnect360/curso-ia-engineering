# Copia este archivo como .env (nunca lo subas al repositorio).
# En Vercel configura estas variables desde Settings → Environment Variables.

# API key de Anthropic (NUNCA en el frontend — solo en el servidor/Vercel)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXX

# Dominio de WordPress donde está embebido el curso.
# El proxy solo acepta peticiones de este origen.
# Deja vacío para aceptar cualquier origen (solo en desarrollo).
ALLOWED_ORIGIN=https://tudominio.com
